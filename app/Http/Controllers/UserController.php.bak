<?php

namespace App\Http\Controllers;

use App\Models\User;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Hash;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Log;
use Spatie\Permission\Models\Role;
use App\Notifications\CompteApprouveNotification;

class UserController extends Controller
{
    /**
     * Étudiant crée son compte librement
     */
    public function create(Request $request)
    {
        // 1️⃣ Validation
        $validated = $request->validate([
            'name'                  => 'required|string|max:255',
            'email'                 => 'required|email|unique:users,email',
            'password'              => 'required|string|min:6|confirmed', // password_confirmation obligatoire
        ]);

        try {
            // 2️⃣ Création de l'utilisateur
            $user = User::create([
                'name'     => $validated['name'],
                'email'    => $validated['email'],
                'password' => Hash::make($validated['password']),
                'status'   => 'pending', // statut par défaut pour étudiant
            ]);

            // 3️⃣ Vérifier si le rôle "etudiant" existe, sinon le créer
            if (!Role::where('name', 'etudiant')->exists()) {
                Role::create(['name' => 'etudiant']);
            }

            // 4️⃣ Assigner le rôle étudiant
            $user->assignRole('etudiant');

            // 5️⃣ Réponse JSON
            return response()->json([
                'success' => true,
                'message' => 'Compte créé avec succès. En attente d’approbation par l’admin.',
                'data' => [
                    'id'     => $user->id,
                    'name'   => $user->name,
                    'email'  => $user->email,
                    'status' => $user->status,
                    'roles'  => $user->getRoleNames(),
                ],
            ], 201);

        } catch (\Throwable $e) {
            // 6️⃣ Gestion des erreurs
            return response()->json([
                'success' => false,
                'message' => 'Erreur lors de la création du compte',
                'error'   => $e->getMessage(),
            ], 500);
        }
    }

    /**
     * Admin approuve un compte étudiant
     */
    public function approve($id)
    {
        $user = User::findOrFail($id);

        if (!$user->hasRole('etudiant')) {
            return response()->json([
                'success' => false,
                'message' => 'Seuls les comptes étudiants peuvent être approuvés.'
            ], 403);
        }
        $user->notify(new CompteApprouveNotification());
        $user->status = 'approved';
        $user->save();

        return response()->json([
            'success' => true,
            'message' => 'Compte approuvé avec succès',
            'data' => [
                'id'     => $user->id,
                'name'   => $user->name,
                'email'  => $user->email,
                'status' => $user->status
            ]
        ]);
    }

    /**
     * Liste tous les utilisateurs (admin)
     */
    public function index()
    {
        $users = User::all();
        return response()->json([
            'success' => true,
            'data' => $users
        ]);
    }

    /**
     * Affiche un utilisateur
     */
    public function show($id)
    {
        $user = User::findOrFail($id);
        return response()->json([
            'success' => true,
            'data' => $user
        ]);
    }
    
}
